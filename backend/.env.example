# VM 배포용 — systemd EnvironmentFile로 로드됨 (backend-implementation.md §1-2)
# 이 파일 자체는 예시일 뿐, 실제 값이 채워진 .env는 절대 커밋하지 않는다.

DJANGO_SECRET_KEY=여기에-충분히-긴-랜덤-문자열
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-subdomain.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-subdomain.example.com

DB_NAME=codebee
DB_USER=codebee
DB_PASSWORD=codebee
DB_HOST=localhost
DB_PORT=5432

REDIS_HOST=localhost
REDIS_PORT=6379

ITEM_ATTACH_PROB=0.2
